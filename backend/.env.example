# ============================================
# PG Manager Pro — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control!

# Database
DB_URL=jdbc:mysql://localhost:3306/pg_hostel_management?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root123

# JWT (generate a strong Base64 secret, minimum 32 chars)
# Example: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# Email (Gmail App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=pgms.hostel@gmail.com
MAIL_PASSWORD=gpji lsut fohf eurf

# Server
SERVER_PORT=8080

# File Uploads
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
