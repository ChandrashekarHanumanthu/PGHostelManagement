# ============================================
# PG Manager Pro — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control!

# Database
# Clever Cloud / managed MySQL example:
DB_URL=jdbc:mysql://your-mysql-host:3306/your-database-name?serverTimezone=UTC
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_MAX_POOL_SIZE=1
DB_MIN_IDLE=0
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000
DB_INIT_FAIL_TIMEOUT_MS=-1

# JWT (generate a strong Base64 secret, minimum 32 chars)
# Example: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# Email (Gmail App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=pgms.hostel@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Server
SERVER_PORT=8080

# JPA / schema handling
SPRING_JPA_HIBERNATE_DDL_AUTO=none

# File Uploads
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
